{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    /* ── Target & Module ─────────────────────────────────────── */
    "target":           "ES2017",
    "lib":              ["dom", "dom.iterable", "esnext"],
    "module":           "esnext",
    "moduleResolution": "bundler",

    /* ── JSX ──────────────────────────────────────────────────── */
    "jsx": "preserve",

    /* ── Strictness — all on ──────────────────────────────────── */
    "strict":                    true,
    "noEmit":                    true,
    "noUnusedLocals":            true,
    "noUnusedParameters":        true,
    "noImplicitReturns":         true,
    "noFallthroughCasesInSwitch": true,

    /* ── Module resolution ────────────────────────────────────── */
    "allowJs":           true,
    "skipLibCheck":      true,
    "esModuleInterop":   true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,   /* enables: import pkg from 'package.json' */
    "isolatedModules":   true,

    /* ── Incremental ──────────────────────────────────────────── */
    "incremental": true,

    /* ── Next.js plugin ──────────────────────────────────────── */
    "plugins": [{ "name": "next" }],

    /* ── Path aliases ─────────────────────────────────────────── */
    "paths": {
      "@/*":            ["./*"],
      "@/components/*": ["./components/*"],
      "@/data/*":       ["./data/*"],
      "@/lib/*":        ["./lib/*"],
      "@/app/*":        ["./app/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}